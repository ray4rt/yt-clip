# ==========================================
# YouTube Clipper - Environment Configuration
# ==========================================

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Folders (relative to project root, atau absolute path)
TEMP_FOLDER=./temp
OUTPUT_FOLDER=./output
DOWNLOAD_FOLDER=./downloads
LOG_FOLDER=./logs

# External Binaries (kosongkan jika sudah ada di PATH sistem)
YTDLP_PATH=yt-dlp
FFMPEG_PATH=
FFPROBE_PATH=

# Job / Queue
MAX_CONCURRENT_JOBS=2
FILE_TTL_MINUTES=30
CLEANUP_INTERVAL_MINUTES=5
MAX_CLIP_DURATION_SECONDS=1800

# Cache
CACHE_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
RATE_LIMIT_CLIP_MAX=5

# Security
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
